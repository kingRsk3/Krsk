        <span class="cart-count" id="cartCount">0</span>
      </div>
    </div>
  </header>

  <!-- hero -->
  <div class="hero-banner">
    <div class="hero-text">
      <h1>🔥 Akara & Kuli Kuli Bliss</h1>
      <p>Handcrafted • 50+ flavors • RSK exclusive</p>
    </div>
    <div class="hero-badge">⭐ RSK EXCLUSIVE</div>
  </div>

  <!-- categories -->
  <div class="categories">
    <span class="category-chip">🍓 Akara</span>
    <span class="category-chip">🥜 Kuli Kuli</span>
    <span class="category-chip">⭐ Best Sellers</span>
    <span class="category-chip">🌈 Rainbow</span>
    <span class="category-chip">🍫 Chocolate</span>
    <span class="category-chip">🍯 Honey</span>
  </div>

  <!-- flash sale -->
  <div class="flash-sale">
    <h2>⚡ Flash Sale <span style="font-size:0.9rem;font-weight:400;">ends in</span></h2>
    <div class="countdown" id="countdownTimer">02:15:30</div>
  </div>

  <!-- product grid -->
  <div class="product-grid" id="productGrid"></div>

  <!-- footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-col"><h4>KING RSK HUB</h4><p>Authentic Akara & Kuli Kuli since 2024</p></div>
      <div class="footer-col"><h4>📍 Lagos • Abuja • PH</h4><p>Delivery across Nigeria</p></div>
      <div class="footer-col"><h4>📞 +234 800 RSK HUB</h4><p>support@rskakara.com</p></div>
    </div>
    <div class="footer-copy">© 2026 KING RSK AKARA & KULI KULI HUB — All rights reserved.</div>
  </footer>

  <script>
    (function() {
      // ---------- PRODUCT DATA (20 Akara + 20 Kuli Kuli) ----------
      const productNames = [
        // Akara (20)
        "Strawberry Akara", "Mango Flavor Akara", "Chocolate Akara", "Honey Glazed Akara",
        "Coconut Akara", "Pineapple Akara", "Banana Akara", "Blueberry Akara",
        "Rainbow Sprinkle Akara", "Vanilla Dream Akara", "Caramel Akara", "Peanut Butter Akara",
        "Cinnamon Akara", "Matcha Akara", "Orange Zest Akara", "Lemon Burst Akara",
        "Pistachio Akara", "Maple Akara", "Toffee Akara", "Mint Choco Akara",
        // Kuli Kuli (20)
        "Strawberry Kuli Kuli", "Mango Flavor Kuli Kuli", "Chocolate Kuli Kuli", "Honey Kuli Kuli",
        "Blueberry Kuli Kuli", "Rainbow Kuli Kuli", "Coconut Kuli Kuli", "Pineapple Kuli Kuli",
        "Banana Kuli Kuli", "Vanilla Kuli Kuli", "Caramel Kuli Kuli", "Peanut Kuli Kuli",
        "Cinnamon Kuli Kuli", "Matcha Kuli Kuli", "Orange Kuli Kuli", "Lemon Kuli Kuli",
        "Pistachio Kuli Kuli", "Maple Kuli Kuli", "Toffee Kuli Kuli", "Mint Kuli Kuli"
      ];

      // generate random price, old price, rating, exclusive
      function rand(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }

      const products = productNames.map((name, idx) => {
        const price = rand(1200, 4500);
        const discount = rand(0, 30);
        const oldPrice = discount > 0 ? Math.round(price * (1 + discount/100)) : null;
        const rating = (rand(35, 50) / 10).toFixed(1);
        const isExclusive = idx % 3 === 0 || idx % 7 === 0; // RSK exclusive badge
        const isDiscount = discount > 12;
        const category = name.includes('Kuli') ? 'Kuli Kuli' : 'Akara';
        // colorful placeholder image: emoji + bg
        const emoji = name.includes('Strawberry')?'🍓':name.includes('Mango')?'🥭':name.includes('Chocolate')?'🍫':
                      name.includes('Honey')?'🍯':name.includes('Coconut')?'🥥':name.includes('Pineapple')?'🍍':
                      name.includes('Banana')?'🍌':name.includes('Blueberry')?'🫐':name.includes('Rainbow')?'🌈':
                      name.includes('Vanilla')?'🍦':name.includes('Caramel')?'🍮':name.includes('Peanut')?'🥜':
                      name.includes('Cinnamon')?'🌰':name.includes('Matcha')?'🍵':name.includes('Orange')?'🍊':
                      name.includes('Lemon')?'🍋':name.includes('Pistachio')?'🟢':name.includes('Maple')?'🍁':
                      name.includes('Toffee')?'🍬':name.includes('Mint')?'🌿':'🍡';
        return {
          id: idx,
          name,
          price,
          oldPrice,
          rating: parseFloat(rating),
          exclusive: isExclusive,
          discount: isDiscount ? `${discount}%` : '',
          category,
          emoji,
          imgLabel: `${emoji} ${name}`,
        };
      });

      // ---------- RENDER ----------
      const grid = document.getElementById('productGrid');
      let cartCount = 0;
      const cartCountEl = document.getElementById('cartCount');

      function renderProducts(filter = '') {
        const q = filter.trim().toLowerCase();
        let html = '';
        let filtered = products;
        if (q) {
          filtered = products.filter(p => p.name.toLowerCase().includes(q) || p.category.toLowerCase().includes(q));
        }
        filtered.forEach(p => {
          const stars = '⭐'.repeat(Math.floor(p.rating)) + (p.rating % 1 >= 0.5 ? '☆' : '');
          const oldPriceHtml = p.oldPrice ? `<span class="old-price">₦${p.oldPrice.toLocaleString()}</span>` : '';
          const discountHtml = p.discount ? `<span class="discount-badge">-${p.discount}</span>` : '';
          const exclusiveHtml = p.exclusive ? `<span class="badge-rsk">RSK Exclusive</span>` : '';

          html += `
            <div class="product-card" data-name="${p.name.toLowerCase()}">
              <div class="product-img">
                <span>${p.emoji} ${p.name}</span>
                ${exclusiveHtml}
                ${discountHtml}
              </div>
              <div class="product-title">${p.name}</div>
              <div class="product-price">₦${p.price.toLocaleString()} ${oldPriceHtml}</div>
              <div class="rating">${stars} <span>(${p.rating})</span></div>
              <div class="card-actions">
                <button class="add-to-cart" data-id="${p.id}">🛒 Add</button>
                <span class="wishlist-icon" data-id="${p.id}">♡</span>
              </div>
            </div>
          `;
        });
        grid.innerHTML = html || '<p style="grid-column:1/-1;padding:40px;text-align:center;font-size:1.2rem;color:#7f6e5a;">✨ No products found. Try a different search.</p>';
      }

      renderProducts();

      // ---------- SEARCH ----------
      const searchInput = document.getElementById('searchInput');
      const searchBtn = document.getElementById('searchBtn');

      function handleSearch() {
        renderProducts(searchInput.value);
      }
      searchBtn.addEventListener('click', handleSearch);
      searchInput.addEventListener('keyup', (e) => { if (e.key === 'Enter') handleSearch(); });

      // ---------- CART COUNT & ADD TO CART (delegation) ----------
      grid.addEventListener('click', (e) => {
        const btn = e.target.closest('.add-to-cart');
        if (btn) {
          cartCount++;
          cartCountEl.textContent = cartCount;
          // subtle feedback
          btn.textContent = '✅ Added';
          setTimeout(() => { btn.innerHTML = '🛒 Add'; }, 800);
          return;
        }
        // wishlist heart toggle
        const heart = e.target.closest('.wishlist-icon');
        if (heart) {
          if (heart.textContent === '♡') {
            heart.textContent = '❤️';
            heart.style.color = '#e63946';
          } else {
            heart.textContent = '♡';
            heart.style.color = '#b0a090';
          }
        }
      });

      // ---------- FLASH SALE COUNTDOWN (2h countdown) ----------
      let totalSeconds = 2 * 3600 + 15 * 60 + 30; // 2:15:30
      const timerEl = document.getElementById('countdownTimer');

      function updateTimer() {
        if (totalSeconds <= 0) {
          timerEl.textContent = '🔥 SOLD OUT';
          return;
        }
        const h = Math.floor(totalSeconds / 3600);
        const m = Math.floor((totalSeconds % 3600) / 60);
        const s = totalSeconds % 60;
        timerEl.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
        totalSeconds--;
      }
      updateTimer();
      setInterval(updateTimer, 1000);

      // ---------- ADDITIONAL: wishlist heart in header (dummy) ----------
      document.querySelector('.wishlist-heart')?.addEventListener('click', function() {
        alert('❤️ Your wishlist (demo) — heart items to save them!');
      });

      // cart icon click
      document.querySelector('.cart-icon')?.addEventListener('click', function() {
        alert(`🛒 You have ${cartCount} item(s) in your cart.`);
      });

      // re-run cart count update if any external
      console.log('KING RSK AKARA & KULI KULI HUB loaded');
    })();
  </script>
</body>
</html>
